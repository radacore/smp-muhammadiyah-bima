#--------------------------------------------------------------------
# Sekolah (CodeIgniter 4) — Docker environment
# Most values are also injected via docker-compose service env (which
# takes precedence over this file), but we keep this in sync for clarity
# and for running tooling like `php spark` inside the container.
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8081/'
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = db
database.default.database = sekolah
database.default.username = muhammadiyah
database.default.password = muhammadiyah
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_unicode_ci

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

